# Supabase Project Settings
# Create these from Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Demo identifiers used by the dashboard and ESP32 firmware contract
NEXT_PUBLIC_VERDE_USER_ID=00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_VERDE_NODE_ID=11111111-1111-1111-1111-111111111111
NEXT_PUBLIC_VERDE_NODE_SLUG=aarav-node-1

# Server-only secrets. Never expose these in the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
VERDE_NODE_API_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_HARDWARE_SECRET

# Future AI integrations
PLANT_ID_API_KEY=YOUR_PLANT_ID_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY

# Weather location for rain override
VERDE_WEATHER_CITY=Delhi,IN

OPENROUTER_API_KEY=YOUR_OPTIONAL_OPENROUTER_KEY

OPENROUTER_MODEL=google/gemini-2.0-flash-001

NEXT_PUBLIC_APP_URL=https://YOUR_DEPLOYED_APP_URL
